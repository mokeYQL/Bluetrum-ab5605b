        <mxCell id="c2_up" value="SCO 上行 ✅&#xa;MIC→手机" style="edgeStyle=none;rounded=0;exitX=0.5;exitY=0;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;fontSize=10;endArrow=block;" edge="1" parent="1" source="c2_mic" target="c2_phone">
