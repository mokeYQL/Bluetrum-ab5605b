        <mxCell id="c2_down" value="SCO 下行 ✅&#xa;对方声音→喇叭" style="edgeStyle=none;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="c2_phone" target="c2_chip">
          <mxGeometry relative="1" as="geometry"/>
